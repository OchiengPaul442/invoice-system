DATABASE_URL="postgresql://user:password@localhost:5432/invoice-app"
NEXTAUTH_SECRET="your-secret-key-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="InvoiceFlow"
UPLOAD_DIR="./public/uploads"
MAX_UPLOAD_SIZE_MB=5
EMAIL_FROM="InvoiceFlow <noreply@your-domain.com>"

# Email provider (choose one)
# Option A: Resend (free tier)
RESEND_API_KEY=""

# Option B: SMTP (Nodemailer, works with Gmail SMTP, Zoho, Mailgun SMTP, etc.)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_SECURE="false"

# Cloudinary PDF storage for invoices
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_FOLDER="invoiceflow/invoices"

# Currency conversion API (no key required by default endpoint)
EXCHANGE_RATES_API_URL="https://open.er-api.com/v6/latest/USD"
